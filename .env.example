# Copy to .env.local and fill in. .env.local is gitignored.

# Vercel personal access token (full account access).
# Named VC_* because Vercel reserves the VERCEL_ prefix for its own system
# variables and rejects custom env vars that start with it.
VC_TOKEN=

# Team scope for all API calls.
VC_TEAM_ID=

# HTTP Basic auth for the dashboard. Auth is skipped when DASHBOARD_PASSWORD is
# empty. Set both before deploying this console anywhere public, since its API
# can trigger deployments with the Vercel token above.
DASHBOARD_USER=
DASHBOARD_PASSWORD=
